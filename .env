# ═══════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
TRUST_PROXY=true
REQUEST_TIMEOUT=30000
BODY_LIMIT=1048576

# ═══════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Notify
DB_USER=postgres
DB_PASSWORD=postgres

# Connection Pool (adjust based on your server)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

